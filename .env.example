# ─── JALAR — environment variables ───────────────────────────────────────────
# Salin file ini jadi `.env.local` lalu isi nilainya. `.env.local` tidak di-commit.

# Midtrans (dari dashboard Midtrans → Settings → Access Keys)
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxx
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxx
# false = sandbox (testing), true = production
MIDTRANS_IS_PRODUCTION=false
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# Supabase (dari dashboard Supabase → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# RAHASIA — service_role key (server-side only, melewati RLS). JANGAN ekspos ke client.
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxx

# URL situs (opsional, untuk metadata/SEO)
NEXT_PUBLIC_SITE_URL=https://jalar.vercel.app
